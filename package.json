{
  "name": "claude-usage-float-ext",
  "version": "1.0.0",
  "description": "Browser extension for Claude API usage monitoring",
  "type": "module",
  "scripts": {
    "build": "npm run build:sw && npm run build:popup && node build-fix.js",
    "build:sw": "vite build --config vite.config.sw.ts",
    "build:popup": "vite build --config vite.config.popup.ts",
    "dev:sw": "vite build --config vite.config.sw.ts --watch",
    "dev:popup": "vite build --config vite.config.popup.ts --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.284",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
